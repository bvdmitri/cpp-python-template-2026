# Doxygen configuration (templated by CMake). Themed with doxygen-awesome-css.
PROJECT_NAME           = "mylib"
PROJECT_NUMBER         = "@DOXYGEN_PROJECT_NUMBER@"
PROJECT_BRIEF          = "A 2026-grade modern C++ library template"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"

INPUT                  = @DOXYGEN_INPUT_DIR@
FILE_PATTERNS          = *.hpp *.h *.cpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = @PROJECT_SOURCE_DIR@/docs/index.md

EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
QUIET                  = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS
GENERATE_LATEX         = NO

# C++ niceties
BUILTIN_STL_SUPPORT    = YES
HAVE_DOT               = @DOXYGEN_HAVE_DOT@
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

# --- doxygen-awesome-css theme ---------------------------------------------
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
GENERATE_HTML          = YES
HTML_EXTRA_STYLESHEET  = @DOXYGEN_AWESOME_CSS_DIR@/doxygen-awesome.css \
                         @DOXYGEN_AWESOME_CSS_DIR@/doxygen-awesome-sidebar-only.css
HTML_COLORSTYLE_GAMMA  = 113
HTML_COLORSTYLE_SAT    = 100
